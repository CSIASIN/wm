{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wmblocks/hero1",
  "version": "0.1.0",
  "title": "Hero 1 — Centered",
  "category": "watermelon-blocks",
  "icon": "cover-image",
  "description": "Centered hero with logo, headline, subtext and two buttons.",
  "supports": {
    "html": false,
    "anchor": true
  },
  "attributes": {
    "logoUrl": {
      "type": "string",
      "default": ""
    },
    "logoId": {
      "type": "number",
      "default": 0
    },
    "logoHeight": {
      "type": "string",
      "default": "72px"
    },
    "heading": {
      "type": "string",
      "default": "Centered hero"
    },
    "subtext": {
      "type": "string",
      "default": "Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit."
    },
    "btn1Text": {
      "type": "string",
      "default": "Primary button"
    },
    "btn1Url": {
      "type": "string",
      "default": "#"
    },
    "btn1Variant": {
      "type": "string",
      "default": "btn-primary"
    },
    "btn2Text": {
      "type": "string",
      "default": "Secondary"
    },
    "btn2Url": {
      "type": "string",
      "default": "#"
    },
    "btn2Variant": {
      "type": "string",
      "default": "btn-outline-secondary"
    },
    "bgColor": {
      "type": "string",
      "default": ""
    },
    "customClass": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "wm",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}