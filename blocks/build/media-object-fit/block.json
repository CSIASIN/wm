{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wmblocks/object-fit",
  "version": "0.1.0",
  "title": "Media Object Fit",
  "category": "watermelon-blocks",
  "icon": "format-video",
  "description": "Bootstrap object-fit utilities for images, videos and iframes — control how media fills its container.",
  "example": {},
  "supports": {
    "html": false,
    "anchor": true
  },
  "attributes": {
    "mediaType": {
      "type": "string",
      "default": "image"
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "videoId": {
      "type": "number",
      "default": 0
    },
    "iframeSrc": {
      "type": "string",
      "default": ""
    },
    "iframeTitle": {
      "type": "string",
      "default": ""
    },
    "objectFit": {
      "type": "string",
      "default": "object-fit-cover"
    },
    "objectFitSm": {
      "type": "string",
      "default": ""
    },
    "objectFitMd": {
      "type": "string",
      "default": ""
    },
    "objectFitLg": {
      "type": "string",
      "default": ""
    },
    "objectFitXl": {
      "type": "string",
      "default": ""
    },
    "width": {
      "type": "string",
      "default": "100%"
    },
    "height": {
      "type": "string",
      "default": "300px"
    },
    "rounded": {
      "type": "string",
      "default": ""
    },
    "autoplay": {
      "type": "boolean",
      "default": false
    },
    "muted": {
      "type": "boolean",
      "default": true
    },
    "loop": {
      "type": "boolean",
      "default": false
    },
    "controls": {
      "type": "boolean",
      "default": true
    },
    "allowFullscreen": {
      "type": "boolean",
      "default": true
    },
    "customClass": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "wm",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}