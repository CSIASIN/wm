{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wmblocks/hero6",
  "version": "0.1.0",
  "title": "Hero 6 — Dark",
  "category": "watermelon-blocks",
  "icon": "cover-image",
  "description": "Dark background hero with headline, subtext, and buttons.",
  "supports": {
    "html": false,
    "anchor": true
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Dark color hero"
    },
    "subtext": {
      "type": "string",
      "default": "Quickly design and customize responsive mobile-first sites with Bootstrap, the world's most popular front-end open source toolkit."
    },
    "btn1Text": {
      "type": "string",
      "default": "Custom button"
    },
    "btn1Url": {
      "type": "string",
      "default": "#"
    },
    "btn1Variant": {
      "type": "string",
      "default": "btn-outline-light"
    },
    "btn2Text": {
      "type": "string",
      "default": "Secondary"
    },
    "btn2Url": {
      "type": "string",
      "default": "#"
    },
    "btn2Variant": {
      "type": "string",
      "default": "btn-outline-secondary"
    },
    "bgColor": {
      "type": "string",
      "default": "bg-dark text-white"
    },
    "customClass": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "wm",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}