      "type": "boolean",
      "default": false
    },
    "borderColour": {
      "type": "string",
      "default": ""
    },
    "borderless": {
      "type": "boolean",
      "default": false
    },
    "small": {
      "type": "boolean",
      "default": false
    },
    "responsive": {
      "type": "string",
      "default": ""
    },
    "verticalAlign": {
      "type": "string",
      "default": ""
    },
    "divider": {
      "type": "boolean",
      "default": false
    }
