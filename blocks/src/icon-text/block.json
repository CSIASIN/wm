{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "wmblocks/icon-text",
    "version": "0.1.0",
    "title": "Icon Text",
    "category": "watermelon-blocks",
    "icon": "editor-textcolor",
    "description": "An inline icon accompanied by customizable text, rendered inside your choice of a structural HTML wrapper.",
    "example": {},
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
          "anchor": {
            "type": "string",
            "default": ""
        },
        "wrapperTag": {
            "type": "string",
            "default": "p"
        },
        "text": {
            "type": "string",
            "default": "Icon text element"
        },
        "iconSvg": {
            "type": "string",
            "default": ""
        },
        "iconPosition": {
            "type": "string",
            "default": "start"
        },
        "hoverAnim": {
            "type": "boolean",
            "default": false
        },
        "textColor": {
            "type": "string",
            "default": ""
        },
        "underlineClass": {
            "type": "string",
            "default": ""
        },
        "textOpacity": {
            "type": "string",
            "default": ""
        },
        "fontSize": {
            "type": "string",
            "default": ""
        },
        "gap": {
            "type": "string",
            "default": ""
        },
        "customClass": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "wm",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}