{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wmblocks/jumbotron4",
	"version": "0.1.0",
	"title": "Jumbotron 4 — Basic",
	"category": "watermelon-blocks",
	"icon": "star-filled",
	"description": "Simple Bootstrap jumbotron sitting within a container, built with utility classes.",
	"supports": { "html": false, "anchor": true },
	"attributes": {
		"heading":     { "type": "string", "default": "Basic jumbotron" },
		"subtext":     { "type": "string", "default": "This is a simple Bootstrap jumbotron that sits within a .container, recreated with built-in utility classes." },
		"btn1Text":    { "type": "string", "default": "Call to action" },
		"btn1Url":     { "type": "string", "default": "#" },
		"btn1Variant": { "type": "string", "default": "btn-primary" },
		"btn2Text":    { "type": "string", "default": "Secondary" },
		"btn2Url":     { "type": "string", "default": "#" },
		"btn2Variant": { "type": "string", "default": "btn-outline-secondary" },
		"bgColor":     { "type": "string", "default": "bg-body-tertiary" },
		"rounded":     { "type": "string", "default": "rounded-3" },
		"customClass": { "type": "string", "default": "" }
	},
	"textdomain": "wm",
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        "file:./style-index.css",
	"render":       "file:./render.php"
}
